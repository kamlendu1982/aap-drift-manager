# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── LLM Configuration (choose one) ────────────────────────────────────

# Option A: Red Hat MaaS / any OpenAI-compatible endpoint
MAAS_API_KEY=your_maas_api_key_here
MAAS_API_BASE=https://your-maas-endpoint.example.com/v1
MAAS_MODEL=llama-4-scout-17b-16e-w4a16

# Option B: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_NAME=gpt-4o

# ── AAP Controller ─────────────────────────────────────────────────────
# URL of your AAP Controller (EC2 hostname or FQDN)
AAP_MCP_SERVER_URL=https://your-aap-controller.example.com
# OR: AAP_URL=https://your-aap-controller.example.com

# AAP API token (create under your profile → Tokens in the AAP UI)
AAP_API_TOKEN=your_aap_api_token_here
# OR: AAP_TOKEN=your_aap_api_token_here

# Set to true only if your AAP has a valid, trusted TLS certificate
AAP_VERIFY_SSL=false

# ── Git CaaC Repository ────────────────────────────────────────────────
# SSH URL (recommended) or HTTPS URL or local path
GIT_REPO_PATH=git@github.com:your-org/caac-aap.git
GIT_BRANCH=main

# ── Agent Behaviour ────────────────────────────────────────────────────
# true  = report only, no changes applied to AAP
# false = apply all drift corrections to AAP
DRY_RUN=true

LOG_LEVEL=INFO
