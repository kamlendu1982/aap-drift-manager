# ── Secrets — NEVER commit these ──────────────────────────────────────
.env
*.key
*.pem
*.p12
*.pfx
*_rsa
*_rsa.pub
manifest_*.zip

# ── Python bytecode ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ───────────────────────────────────────────────
venv/
.venv/
env/
.env.local

# ── Testing & coverage ────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ── Logs & temp files ─────────────────────────────────────────────────
*.log
logs/
/tmp/aap-drift-caac-*/

# ── IDE / OS ───────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
